  "condition_specific_exercise": {
    "type_2_diabetes": {
      "aerobic_minutes_per_week": 150,
      "resistance_sessions_per_week": 2,
      "avoid": ["exercising with blood glucose >250 mg/dL with ketones", "prolonged intense exercise if hypoglycemia prone"],
      "precautions": [
        "Check blood glucose before and after exercise",
        "Carry fast-acting carbohydrate",
        "Avoid exercise during peak insulin activity",
