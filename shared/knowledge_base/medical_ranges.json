      "direct_bilirubin": {
        "name": "Direct Bilirubin",
        "unit": "mg/dL",
        "ranges": {
          "all": {
            "adult": {"low": 0.0, "high": 0.3}
          }
        },
        "description": "Conjugated bilirubin; elevated in obstructive liver disease"
