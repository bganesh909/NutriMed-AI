{
  "biomarkers": {
    "complete_blood_count": {
      "hemoglobin": {
        "name": "Hemoglobin",
        "unit": "g/dL",
        "ranges": {
          "male": {
            "adult": {"low": 13.5, "high": 17.5},
            "elderly_60_plus": {"low": 12.5, "high": 17.0},
            "child_6_12": {"low": 11.5, "high": 15.5}
          },
          "female": {
            "adult": {"low": 12.0, "high": 16.0},
            "pregnant": {"low": 11.0, "high": 14.0},
            "elderly_60_plus": {"low": 11.5, "high": 16.0},
            "child_6_12": {"low": 11.5, "high": 15.5}
          }
        },
        "critical_low": 7.0,
        "critical_high": 20.0,
        "description": "Oxygen-carrying protein in red blood cells",
        "clinical_significance": "Low values indicate anemia; high values may indicate polycythemia or dehydration"
      },
      "hematocrit": {
        "name": "Hematocrit",
        "unit": "%",
        "ranges": {
          "male": {
            "adult": {"low": 38.3, "high": 48.6}
          },
          "female": {
            "adult": {"low": 35.5, "high": 44.9},
            "pregnant": {"low": 33.0, "high": 44.0}
          }
        },
        "critical_low": 20.0,
        "critical_high": 60.0,
        "description": "Percentage of blood volume occupied by red blood cells"
      },
      "rbc_count": {
        "name": "Red Blood Cell Count",
        "unit": "million/uL",
        "ranges": {
          "male": {
            "adult": {"low": 4.7, "high": 6.1}
          },
          "female": {
            "adult": {"low": 4.2, "high": 5.4}
          }
        },
        "description": "Total number of red blood cells per microliter"
      },
      "wbc_count": {
        "name": "White Blood Cell Count",
        "unit": "cells/uL",
        "ranges": {
          "all": {
            "adult": {"low": 4500, "high": 11000},
            "child": {"low": 5000, "high": 13000}
          }
        },
        "critical_low": 2000,
        "critical_high": 30000,
        "description": "Total number of white blood cells indicating immune function"
      },
      "platelet_count": {
        "name": "Platelet Count",
        "unit": "cells/uL",
        "ranges": {
          "all": {
            "adult": {"low": 150000, "high": 400000}
          }
        },
        "critical_low": 50000,
        "critical_high": 1000000,
        "description": "Blood clotting cells"
      },
      "mcv": {
        "name": "Mean Corpuscular Volume",
        "unit": "fL",
        "ranges": {
          "all": {
            "adult": {"low": 80.0, "high": 100.0}
          }
        },
        "description": "Average red blood cell size; low in iron deficiency, high in B12/folate deficiency"
      },
      "mch": {
        "name": "Mean Corpuscular Hemoglobin",
        "unit": "pg",
        "ranges": {
          "all": {
            "adult": {"low": 27.0, "high": 33.0}
          }
        },
        "description": "Average hemoglobin content per red blood cell"
      },
      "mchc": {
        "name": "Mean Corpuscular Hemoglobin Concentration",
        "unit": "g/dL",
        "ranges": {
          "all": {
            "adult": {"low": 32.0, "high": 36.0}
          }
        },
        "description": "Average hemoglobin concentration in red blood cells"
      },
      "rdw": {
        "name": "Red Cell Distribution Width",
        "unit": "%",
        "ranges": {
          "all": {
            "adult": {"low": 11.5, "high": 14.5}
          }
        },
        "description": "Variation in red blood cell size; elevated in mixed anemias"
      },
      "esr": {
        "name": "Erythrocyte Sedimentation Rate",
        "unit": "mm/hr",
        "ranges": {
          "male": {
            "adult_under_50": {"low": 0, "high": 15},
            "adult_over_50": {"low": 0, "high": 20}
          },
          "female": {
            "adult_under_50": {"low": 0, "high": 20},
            "adult_over_50": {"low": 0, "high": 30}
          }
        },
        "description": "Non-specific marker of inflammation"
      }
    },
    "lipid_panel": {
      "total_cholesterol": {
        "name": "Total Cholesterol",
        "unit": "mg/dL",
        "ranges": {
          "all": {
            "desirable": {"low": 0, "high": 200},
            "borderline_high": {"low": 200, "high": 239},
            "high": {"low": 240, "high": 9999}
          }
        },
        "description": "Total blood cholesterol level per ATP III guidelines",
        "clinical_significance": "Major risk factor for cardiovascular disease"
      },
      "ldl_cholesterol": {
        "name": "LDL Cholesterol",
        "unit": "mg/dL",
        "ranges": {
          "all": {
            "optimal": {"low": 0, "high": 100},
            "near_optimal": {"low": 100, "high": 129},
            "borderline_high": {"low": 130, "high": 159},
            "high": {"low": 160, "high": 189},
            "very_high": {"low": 190, "high": 9999}
          }
        },
        "description": "Low-density lipoprotein; primary target for cholesterol management"
      },
      "hdl_cholesterol": {
        "name": "HDL Cholesterol",
        "unit": "mg/dL",
        "ranges": {
          "male": {
            "low_risk": {"low": 60, "high": 9999},
            "moderate": {"low": 40, "high": 59},
            "high_risk": {"low": 0, "high": 40}
          },
          "female": {
            "low_risk": {"low": 60, "high": 9999},
            "moderate": {"low": 50, "high": 59},
            "high_risk": {"low": 0, "high": 50}
          }
        },
        "description": "High-density lipoprotein; protective against cardiovascular disease"
      },
      "triglycerides": {
        "name": "Triglycerides",
        "unit": "mg/dL",
        "ranges": {
          "all": {
            "normal": {"low": 0, "high": 150},
            "borderline_high": {"low": 150, "high": 199},
            "high": {"low": 200, "high": 499},
            "very_high": {"low": 500, "high": 9999}
          }
        },
        "critical_high": 500,
        "description": "Blood fat level; very high levels risk pancreatitis"
      },
      "vldl": {
        "name": "VLDL Cholesterol",
        "unit": "mg/dL",
        "ranges": {
          "all": {
            "normal": {"low": 2, "high": 30}
          }
        },
        "description": "Very low-density lipoprotein; carries triglycerides"
      }
    },
    "metabolic_panel": {
      "fasting_glucose": {
        "name": "Fasting Blood Glucose",
        "unit": "mg/dL",
        "ranges": {
          "all": {
            "normal": {"low": 70, "high": 99},
            "prediabetes": {"low": 100, "high": 125},
            "diabetes": {"low": 126, "high": 9999}
          }
        },
        "critical_low": 50,
        "critical_high": 400,
        "description": "Blood sugar after 8-12 hour fast; per ADA guidelines"
      },
      "hba1c": {
        "name": "Hemoglobin A1c",
        "unit": "%",
        "ranges": {
          "all": {
            "normal": {"low": 4.0, "high": 5.6},
            "prediabetes": {"low": 5.7, "high": 6.4},
            "diabetes": {"low": 6.5, "high": 15.0}
          }
        },
        "description": "Average blood sugar over 2-3 months; per ADA diagnostic criteria"
      },
      "insulin_fasting": {
        "name": "Fasting Insulin",
        "unit": "uIU/mL",
        "ranges": {
          "all": {
            "optimal": {"low": 2.0, "high": 5.0},
            "normal": {"low": 2.6, "high": 24.9},
            "insulin_resistant": {"low": 25.0, "high": 9999}
          }
        },
        "description": "Fasting insulin level; elevated suggests insulin resistance"
      },
      "bun": {
        "name": "Blood Urea Nitrogen",
        "unit": "mg/dL",
        "ranges": {
          "all": {
            "adult": {"low": 7, "high": 20}
          }
        },
        "description": "Kidney function marker; elevated in dehydration or kidney disease"
      },
      "creatinine": {
        "name": "Serum Creatinine",
        "unit": "mg/dL",
        "ranges": {
          "male": {
            "adult": {"low": 0.74, "high": 1.35}
          },
          "female": {
            "adult": {"low": 0.59, "high": 1.04}
          }
        },
        "description": "Kidney function marker; used to estimate glomerular filtration rate"
      },
      "egfr": {
        "name": "Estimated Glomerular Filtration Rate",
        "unit": "mL/min/1.73m2",
        "ranges": {
          "all": {
            "normal": {"low": 90, "high": 120},
            "mildly_decreased": {"low": 60, "high": 89},
            "moderately_decreased": {"low": 30, "high": 59},
            "severely_decreased": {"low": 15, "high": 29},
            "kidney_failure": {"low": 0, "high": 15}
          }
        },
        "description": "Estimated kidney filtration rate; per KDIGO staging"
      },
      "uric_acid": {
        "name": "Uric Acid",
        "unit": "mg/dL",
        "ranges": {
          "male": {
            "adult": {"low": 3.4, "high": 7.0}
          },
          "female": {
            "adult": {"low": 2.4, "high": 6.0}
          }
        },
        "description": "Elevated levels associated with gout and kidney stones"
      },
      "sodium": {
        "name": "Sodium",
        "unit": "mEq/L",
        "ranges": {
          "all": {
            "adult": {"low": 136, "high": 145}
          }
        },
        "critical_low": 120,
        "critical_high": 160,
        "description": "Electrolyte essential for fluid balance and nerve function"
      },
      "potassium": {
        "name": "Potassium",
        "unit": "mEq/L",
        "ranges": {
          "all": {
            "adult": {"low": 3.5, "high": 5.0}
          }
        },
        "critical_low": 2.5,
        "critical_high": 6.5,
        "description": "Electrolyte critical for heart rhythm and muscle function"
      },
      "calcium": {
        "name": "Calcium",
        "unit": "mg/dL",
        "ranges": {
          "all": {
            "adult": {"low": 8.5, "high": 10.5}
          }
        },
        "critical_low": 6.0,
        "critical_high": 13.0,
        "description": "Essential for bone health, muscle contraction, and nerve signaling"
      }
    },
    "liver_panel": {
      "alt": {
        "name": "Alanine Aminotransferase (ALT/SGPT)",
        "unit": "U/L",
        "ranges": {
          "male": {
            "adult": {"low": 7, "high": 56}
