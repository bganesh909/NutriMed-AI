            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"goal\": \"muscle_gain\",\n  \"difficulty\": \"intermediate\",\n  \"days_per_week\": 4,\n  \"conditions\": [],\n  \"use_biomarkers\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/fitness/generate-workout",
