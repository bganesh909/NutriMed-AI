    {
      "name": "Recommendations",
      "item": [
        {
          "name": "Generate Recommendations",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"report_id\": \"{{report_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/recommendations/generate",
              "host": ["{{base_url}}"],
              "path": ["recommendations", "generate"]
            }
          }
        },
        {
          "name": "List Recommendations",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/recommendations/",
              "host": ["{{base_url}}"],
              "path": ["recommendations", ""]
            }
          }
        },
        {
          "name": "Get Latest Recommendation",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/recommendations/latest",
              "host": ["{{base_url}}"],
              "path": ["recommendations", "latest"]
            }
          }
        }
      ]
    },
    {
      "name": "Progress",
      "item": [
        {
          "name": "Log Progress",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2026-06-15\",\n  \"weight\": 74.5,\n  \"body_fat_pct\": 18.0,\n  \"measurements\": {\n    \"waist\": 82.0,\n    \"chest\": 100.0,\n    \"arms\": 36.0,\n    \"thighs\": 56.0\n  },\n  \"biomarker_snapshot\": {\n    \"hemoglobin\": 14.8,\n    \"vitamin_d\": 28.0\n  },\n  \"notes\": \"Feeling good, energy levels up\"\n}"
            },
