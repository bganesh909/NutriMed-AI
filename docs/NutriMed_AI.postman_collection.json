            "body": {
              "mode": "raw",
              "raw": "{\n  \"weight_kg\": 75,\n  \"height_cm\": 175,\n  \"age\": 28,\n  \"gender\": \"male\",\n  \"activity_level\": \"moderate\",\n  \"goal\": \"maintenance\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/nutrition/calculate",
              "host": ["{{base_url}}"],
              "path": ["nutrition", "calculate"]
            }
          }
        },
        {
          "name": "Calculate from Profile",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/nutrition/calculate",
              "host": ["{{base_url}}"],
              "path": ["nutrition", "calculate"]
            }
          }
        },
        {
          "name": "Generate Diet Plan",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
