            }
          }
        },
        {
          "name": "Get History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/progress/?limit=50&skip=0",
              "host": ["{{base_url}}"],
              "path": ["progress", ""],
              "query": [
                { "key": "limit", "value": "50" },
                { "key": "skip", "value": "0" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "PDF",
      "item": [
        {
          "name": "Download Generated PDF Report",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/pdf/reports/{{report_id}}/pdf",
              "host": ["{{base_url}}"],
              "path": ["pdf", "reports", "{{report_id}}", "pdf"]
            }
          }
        },
        {
          "name": "Download Original Report",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/pdf/report/{{report_id}}",
              "host": ["{{base_url}}"],
              "path": ["pdf", "report", "{{report_id}}"]
            }
          }
        }
      ]
    }
  ]
}
