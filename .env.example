# ===========================================
# NutriMed AI - Environment Configuration
# ===========================================
# Copy this file to .env and update values for your environment.
# NEVER commit the .env file to version control.

# --- Application ---
APP_NAME=NutriMed AI
DEBUG=true

# --- MongoDB ---
MONGO_URI=mongodb://admin:nutrimed_secret@mongo:27017/nutrimed?authSource=admin
MONGO_DB_NAME=nutrimed

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- RabbitMQ ---
RABBITMQ_URL=amqp://nutrimed:nutrimed_secret@rabbitmq:5672//

# --- JWT Authentication ---
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30

# --- Encryption ---
AES_KEY=your-32-byte-aes-encryption-key!!

# --- Ollama / LLM ---
OLLAMA_BASE_URL=http://ollama:11434

# --- Microservice URLs ---
OCR_SERVICE_URL=http://ocr-service:8001
LLM_SERVICE_URL=http://llm-service:8002
NUTRITION_SERVICE_URL=http://nutrition-service:8003
FITNESS_SERVICE_URL=http://fitness-service:8004
PDF_SERVICE_URL=http://pdf-service:8005
RAG_SERVICE_URL=http://rag-service:8006

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
